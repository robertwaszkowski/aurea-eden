<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" id="Definitions_DPE_1_3_Change" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.28.0">
  <bpmn:collaboration id="Collaboration_DPE_1_3_Change">
    <bpmn:participant id="Participant_Pool_WAT_Change" name="MUT (DPE/1-3: Change of Employment Conditions)" processRef="Process_DPE_1_3_Change" />
  </bpmn:collaboration>
  <bpmn:process id="Process_DPE_1_3_Change" isExecutable="true" camunda:versionTag="1.0">
    <bpmn:laneSet id="LaneSet_0p9q7qz">
      <bpmn:lane id="Lane_HeadOU" name="Head of O.U.">
        <bpmn:flowNodeRef>Task_ReviewAndForward_HeadOU</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>StartEvent_ApplicationSubmitted</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_PD" name="PD (Personnel Department)">
        <bpmn:flowNodeRef>Task_ReviewApplication_PD</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_InformHeadOU</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ImplementChanges</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_PrepareDocuments</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_HandOverDocuments</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Archive</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_ProcessEnded</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Quartermaster" name="Quartermaster (KWE)">
        <bpmn:flowNodeRef>Task_Review_KWE</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Chancellor" name="Chancellor (KAN)">
        <bpmn:flowNodeRef>Gateway_IsAcademicTeacher</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_MakeDecision_Chancellor</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_JoinDecision</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_VRE" name="Vice-Rector for Education (PRK)">
        <bpmn:flowNodeRef>Task_Review_PRK</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_VRSA" name="Vice-Rector for Scientific Affairs (PRN)">
        <bpmn:flowNodeRef>Task_Review_PRN</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Rector" name="Rector (RKR)">
        <bpmn:flowNodeRef>Task_MakeDecision_RKR</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:sequenceFlow id="Flow_JoinGateToInform" sourceRef="Gateway_JoinDecision" targetRef="Task_InformHeadOU" />
    <bpmn:sequenceFlow id="Flow_DecisionRKRToJoinGate" sourceRef="Task_MakeDecision_RKR" targetRef="Gateway_JoinDecision" />
    <bpmn:sequenceFlow id="Flow_ReviewPRNToDecisionRKR" sourceRef="Task_Review_PRN" targetRef="Task_MakeDecision_RKR" />
    <bpmn:sequenceFlow id="Flow_ReviewPRKToReviewPRN" sourceRef="Task_Review_PRK" targetRef="Task_Review_PRN" />
    <bpmn:sequenceFlow id="Flow_DecisionKANToJoinGate" sourceRef="Task_MakeDecision_Chancellor" targetRef="Gateway_JoinDecision" />
    <bpmn:sequenceFlow id="Flow_Yes_ToPRK" name="Yes" sourceRef="Gateway_IsAcademicTeacher" targetRef="Task_Review_PRK" />
    <bpmn:sequenceFlow id="Flow_No_ToKAN" name="No (Non-academic employee)" sourceRef="Gateway_IsAcademicTeacher" targetRef="Task_MakeDecision_Chancellor" />
    <bpmn:sequenceFlow id="Flow_ReviewKWEToIsAcademic" sourceRef="Task_Review_KWE" targetRef="Gateway_IsAcademicTeacher" />
    <bpmn:sequenceFlow id="Flow_ReviewPDToKWE" sourceRef="Task_ReviewApplication_PD" targetRef="Task_Review_KWE" />
    <bpmn:sequenceFlow id="Flow_ReviewHeadOUToReviewPD" sourceRef="Task_ReviewAndForward_HeadOU" targetRef="Task_ReviewApplication_PD" />
    <bpmn:sequenceFlow id="Flow_StartToReviewHeadOU" sourceRef="StartEvent_ApplicationSubmitted" targetRef="Task_ReviewAndForward_HeadOU" />
    <bpmn:userTask id="Task_ReviewAndForward_HeadOU" name="Review and forward application to PD">
      <bpmn:incoming>Flow_StartToReviewHeadOU</bpmn:incoming>
      <bpmn:outgoing>Flow_ReviewHeadOUToReviewPD</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:startEvent id="StartEvent_ApplicationSubmitted" name="Change of Employment Conditions Application Submitted">
      <bpmn:outgoing>Flow_StartToReviewHeadOU</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Task_ReviewApplication_PD" name="Review application (PD)">
      <bpmn:incoming>Flow_ReviewHeadOUToReviewPD</bpmn:incoming>
      <bpmn:outgoing>Flow_ReviewPDToKWE</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_InformToImplement" sourceRef="Task_InformHeadOU" targetRef="Task_ImplementChanges" />
    <bpmn:sequenceFlow id="Flow_ImplementToPrepare" sourceRef="Task_ImplementChanges" targetRef="Task_PrepareDocuments" />
    <bpmn:sequenceFlow id="Flow_PrepareToHandOver" sourceRef="Task_PrepareDocuments" targetRef="Task_HandOverDocuments" />
    <bpmn:sequenceFlow id="Flow_HandOverToArchive" sourceRef="Task_HandOverDocuments" targetRef="Task_Archive" />
    <bpmn:sequenceFlow id="Flow_ArchiveToProcessEnd" sourceRef="Task_Archive" targetRef="EndEvent_ProcessEnded" />
    <bpmn:userTask id="Task_Review_KWE" name="Review application (Quartermaster)">
      <bpmn:incoming>Flow_ReviewPDToKWE</bpmn:incoming>
      <bpmn:outgoing>Flow_ReviewKWEToIsAcademic</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_IsAcademicTeacher" name="Concerns an academic teacher?">
      <bpmn:incoming>Flow_ReviewKWEToIsAcademic</bpmn:incoming>
      <bpmn:outgoing>Flow_No_ToKAN</bpmn:outgoing>
      <bpmn:outgoing>Flow_Yes_ToPRK</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_MakeDecision_Chancellor" name="Make decision (KAN) and return to PD">
      <bpmn:incoming>Flow_No_ToKAN</bpmn:incoming>
      <bpmn:outgoing>Flow_DecisionKANToJoinGate</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_Review_PRK" name="Review application (PRK) and forward to PRN">
      <bpmn:incoming>Flow_Yes_ToPRK</bpmn:incoming>
      <bpmn:outgoing>Flow_ReviewPRKToReviewPRN</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_Review_PRN" name="Review application (PRN) and forward to Rector">
      <bpmn:incoming>Flow_ReviewPRKToReviewPRN</bpmn:incoming>
      <bpmn:outgoing>Flow_ReviewPRNToDecisionRKR</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_MakeDecision_RKR" name="Make decision (RKR) and return to PD">
      <bpmn:incoming>Flow_ReviewPRNToDecisionRKR</bpmn:incoming>
      <bpmn:outgoing>Flow_DecisionRKRToJoinGate</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_JoinDecision">
      <bpmn:incoming>Flow_DecisionKANToJoinGate</bpmn:incoming>
      <bpmn:incoming>Flow_DecisionRKRToJoinGate</bpmn:incoming>
      <bpmn:outgoing>Flow_JoinGateToInform</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_InformHeadOU" name="Inform Head of O.U.&#10;about the decision">
      <bpmn:incoming>Flow_JoinGateToInform</bpmn:incoming>
      <bpmn:outgoing>Flow_InformToImplement</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_ImplementChanges" name="Implement changes">
      <bpmn:incoming>Flow_InformToImplement</bpmn:incoming>
      <bpmn:outgoing>Flow_ImplementToPrepare</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_PrepareDocuments" name="Prepare confirming documents">
      <bpmn:incoming>Flow_ImplementToPrepare</bpmn:incoming>
      <bpmn:outgoing>Flow_PrepareToHandOver</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_HandOverDocuments" name="Hand over documents to employee">
      <bpmn:incoming>Flow_PrepareToHandOver</bpmn:incoming>
      <bpmn:outgoing>Flow_HandOverToArchive</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_Archive" name="Attach 1 copy to personnel files">
      <bpmn:incoming>Flow_HandOverToArchive</bpmn:incoming>
      <bpmn:outgoing>Flow_ArchiveToProcessEnd</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="EndEvent_ProcessEnded" name="Service process ended">
      <bpmn:incoming>Flow_ArchiveToProcessEnd</bpmn:incoming>
    </bpmn:endEvent>
  </bpmn:process>
