<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.28.0">
  <bpmn:process id="Process_HeatPumpSales" name="Heat Pump Sales Process" isExecutable="true">
    <bpmn:startEvent id="StartEvent_1" name="Start" />
    <bpmn:task id="Task_AddProspect" name="Add a new prospect (System)" />
    <bpmn:exclusiveGateway id="Gateway_ManualStart" name="Process started manually?" />
    <bpmn:task id="Task_AddContact" name="Add customer contact data (Customer)" />
    <bpmn:task id="Task_FirstAppt" name="The first appointment (Key Account Manager)" />
    <bpmn:task id="Task_PrepareOffer" name="Review data and prepare the offer (eco-Advisor)">
      <bpmn:incoming>Flow_0hk08wz</bpmn:incoming>
    </bpmn:task>
    <bpmn:task id="Task_ReviewOffer" name="Review the offer (Reviewer)" />
    <bpmn:exclusiveGateway id="Gateway_CustomerInterest" name="Customer interested?" />
    <bpmn:task id="Task_ConfirmInterest" name="Confirm customer interested (eco-Advisor)" />
    <bpmn:task id="Task_Payment" name="Make an electronic payment (Customer)" />
    <bpmn:task id="Task_ChooseInstaller" name="Choose the installer (Reviewer)" />
    <bpmn:task id="Task_ChooseAuditor" name="Choose auditor and arrange the audit (Coordinator)" />
    <bpmn:task id="Task_PerformAudit" name="Perform audit (Auditor)" />
    <bpmn:exclusiveGateway id="Gateway_OfferChanges" name="Offer requires changes?">
      <bpmn:outgoing>Flow_0hk08wz</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_SignAgreement" name="Sign the agreement (Auditor)" />
    <bpmn:exclusiveGateway id="Gateway_Financing" name="What financing method?" />
    <bpmn:task id="Task_CreditCheck" name="Check customer credit-worthiness (Reviewer)" />
    <bpmn:exclusiveGateway id="Gateway_LoanDecision" name="Loan granted?" />
    <bpmn:task id="Task_AdvancePayment" name="Accept the advance payment (Accountant)" />
    <bpmn:task id="Task_StartLogistics" name="Start the logistics and installation process (System)">
      <bpmn:outgoing>Flow_1lgh9nh</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="EndEvent_NoAgreement">
      <bpmn:incoming>Flow_1lgh9nh</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_AddProspect" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_AddProspect" targetRef="Gateway_ManualStart" />
    <bpmn:sequenceFlow id="Flow_3" name="Yes" sourceRef="Gateway_ManualStart" targetRef="Task_AddContact" />
    <bpmn:sequenceFlow id="Flow_4" name="No" sourceRef="Gateway_ManualStart" targetRef="Task_FirstAppt" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Task_AddContact" targetRef="Task_FirstAppt" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="Task_FirstAppt" targetRef="Task_PrepareOffer" />
    <bpmn:sequenceFlow id="Flow_7" sourceRef="Task_PrepareOffer" targetRef="Task_ReviewOffer" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="Task_ReviewOffer" targetRef="Gateway_CustomerInterest" />
    <bpmn:sequenceFlow id="Flow_9" name="No" sourceRef="Gateway_CustomerInterest" targetRef="EndEvent_NoAgreement" />
    <bpmn:sequenceFlow id="Flow_10" name="No answer 3 days" sourceRef="Gateway_CustomerInterest" targetRef="Task_ConfirmInterest" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="Task_ConfirmInterest" targetRef="Gateway_CustomerInterest" />
    <bpmn:sequenceFlow id="Flow_12" name="Yes" sourceRef="Gateway_CustomerInterest" targetRef="Task_Payment" />
    <bpmn:sequenceFlow id="Flow_13" sourceRef="Task_Payment" targetRef="Task_ChooseInstaller" />
    <bpmn:sequenceFlow id="Flow_14" sourceRef="Task_ChooseInstaller" targetRef="Task_ChooseAuditor" />
    <bpmn:sequenceFlow id="Flow_15" sourceRef="Task_ChooseAuditor" targetRef="Task_PerformAudit" />
    <bpmn:sequenceFlow id="Flow_16" sourceRef="Task_PerformAudit" targetRef="Gateway_OfferChanges" />
    <bpmn:sequenceFlow id="Flow_17" name="No" sourceRef="Gateway_OfferChanges" targetRef="Task_SignAgreement" />
    <bpmn:sequenceFlow id="Flow_18" sourceRef="Task_SignAgreement" targetRef="Gateway_Financing" />
    <bpmn:sequenceFlow id="Flow_19" name="Cash" sourceRef="Gateway_Financing" targetRef="Task_AdvancePayment" />
    <bpmn:sequenceFlow id="Flow_20" name="Loan" sourceRef="Gateway_Financing" targetRef="Task_CreditCheck" />
    <bpmn:sequenceFlow id="Flow_21" sourceRef="Task_CreditCheck" targetRef="Gateway_LoanDecision" />
    <bpmn:sequenceFlow id="Flow_22" name="Yes" sourceRef="Gateway_LoanDecision" targetRef="Task_AdvancePayment" />
    <bpmn:sequenceFlow id="Flow_23" name="No" sourceRef="Gateway_LoanDecision" targetRef="EndEvent_NoAgreement" />
    <bpmn:sequenceFlow id="Flow_24" sourceRef="Task_AdvancePayment" targetRef="Task_StartLogistics" />
    <bpmn:sequenceFlow id="Flow_1lgh9nh" sourceRef="Task_StartLogistics" targetRef="EndEvent_NoAgreement" />
    <bpmn:sequenceFlow id="Flow_0hk08wz" name="Yes" sourceRef="Gateway_OfferChanges" targetRef="Task_PrepareOffer" />
  </bpmn:process>
