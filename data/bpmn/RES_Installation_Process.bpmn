<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.28.0">
  <bpmn:process id="Process_Installation" name="Heat Pump Installation" isExecutable="true">
    <bpmn:startEvent id="StartEvent_1" name="Start" />
    <bpmn:task id="Task_Schedule" name="Schedule installation with Customer (Installation coordinator)" />
    <bpmn:exclusiveGateway id="Gateway_Contacted" name="Customer contacted?" />
    <bpmn:task id="Task_VerifyFailure" name="Verify contact failure (Operations Manager)" />
    <bpmn:parallelGateway id="Gateway_Parallel_Split" />
    <bpmn:task id="Task_AddDocs" name="Add installer documents (Installer)" />
    <bpmn:task id="Task_GetGoods" name="Get goods from warehouse (Installer)" />
    <bpmn:parallelGateway id="Gateway_Parallel_Join" />
    <bpmn:task id="Task_Install" name="Installation at the customer&#39;s site (Installer)" />
    <bpmn:exclusiveGateway id="Gateway_Reschedule" name="New schedule required?" />
    <bpmn:task id="Task_Reschedule" name="Reschedule installation (Operations Manager)" />
    <bpmn:task id="Task_Protocol" name="Prepare the acceptance protocol (Installer)" />
    <bpmn:parallelGateway id="Gateway_End_Split" />
    <bpmn:task id="Task_Invoice" name="Prepare invoice for customer (Operations Manager)" />
    <bpmn:task id="Task_DocOSD" name="Confirm sending documentation to OSD (Installer)" />
    <bpmn:task id="Task_Verify" name="Verify internally (Operations Manager)" />
    <bpmn:exclusiveGateway id="Gateway_Corrections" name="Corrections required?" />
    <bpmn:task id="Task_Amendments" name="Implement required amendments (Installer)" />
    <bpmn:parallelGateway id="Gateway_End_Join" />
    <bpmn:endEvent id="EndEvent_Finished" name="Installation Complete" />
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_Schedule" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_Schedule" targetRef="Gateway_Contacted" />
    <bpmn:sequenceFlow id="Flow_3" name="No" sourceRef="Gateway_Contacted" targetRef="Task_VerifyFailure" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Task_VerifyFailure" targetRef="Task_Schedule" />
    <bpmn:sequenceFlow id="Flow_5" name="Yes" sourceRef="Gateway_Contacted" targetRef="Gateway_Parallel_Split" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="Gateway_Parallel_Split" targetRef="Task_AddDocs" />
    <bpmn:sequenceFlow id="Flow_7" sourceRef="Gateway_Parallel_Split" targetRef="Task_GetGoods" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="Task_AddDocs" targetRef="Gateway_Parallel_Join" />
    <bpmn:sequenceFlow id="Flow_9" sourceRef="Task_GetGoods" targetRef="Gateway_Parallel_Join" />
    <bpmn:sequenceFlow id="Flow_10" sourceRef="Gateway_Parallel_Join" targetRef="Task_Install" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="Task_Install" targetRef="Gateway_Reschedule" />
    <bpmn:sequenceFlow id="Flow_12" name="Yes" sourceRef="Gateway_Reschedule" targetRef="Task_Reschedule" />
    <bpmn:sequenceFlow id="Flow_13" sourceRef="Task_Reschedule" targetRef="Task_Install" />
    <bpmn:sequenceFlow id="Flow_14" name="No" sourceRef="Gateway_Reschedule" targetRef="Task_Protocol" />
    <bpmn:sequenceFlow id="Flow_15" sourceRef="Task_Protocol" targetRef="Gateway_End_Split" />
    <bpmn:sequenceFlow id="Flow_16" sourceRef="Gateway_End_Split" targetRef="Task_Invoice" />
    <bpmn:sequenceFlow id="Flow_17" sourceRef="Gateway_End_Split" targetRef="Task_DocOSD" />
    <bpmn:sequenceFlow id="Flow_18" sourceRef="Task_DocOSD" targetRef="Task_Verify" />
    <bpmn:sequenceFlow id="Flow_19" sourceRef="Task_Verify" targetRef="Gateway_Corrections" />
    <bpmn:sequenceFlow id="Flow_20" name="Yes" sourceRef="Gateway_Corrections" targetRef="Task_Amendments" />
    <bpmn:sequenceFlow id="Flow_21" sourceRef="Task_Amendments" targetRef="Task_Verify" />
    <bpmn:sequenceFlow id="Flow_22" name="No" sourceRef="Gateway_Corrections" targetRef="Gateway_End_Join" />
    <bpmn:sequenceFlow id="Flow_23" sourceRef="Task_Invoice" targetRef="Gateway_End_Join" />
    <bpmn:sequenceFlow id="Flow_24" sourceRef="Gateway_End_Join" targetRef="EndEvent_Finished" />
  </bpmn:process>
