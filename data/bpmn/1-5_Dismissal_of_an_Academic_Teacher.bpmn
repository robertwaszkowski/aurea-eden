<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_DPE_1_5" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.28.0">
  <bpmn:collaboration id="Collaboration_DPE_1_5">
    <bpmn:participant id="Participant_Pool_WAT" name="Military University of Technology (Dismissal of an Academic Teacher DPE/1-5)" processRef="Process_DPE_1_5" />
  </bpmn:collaboration>
  <bpmn:process id="Process_DPE_1_5" isExecutable="true" camunda:versionTag="1.0">
    <bpmn:laneSet id="LaneSet_DPE_1_5">
      <bpmn:lane id="Lane_Kierownik_JO" name="Head of O.U. / Vice-Rector for Education (PRK)">
        <bpmn:flowNodeRef>Task_ReviewApplicationEmployee</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>StartEvent_ProcessInitiation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_WhoInitiates</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ConsultDraftWithLSS</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SubmitApplicationToPD</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_HandOverDismissalNotice</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_DPE" name="PD (Personnel Department)">
        <bpmn:flowNodeRef>Task_ReviewApplicationPD</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_InformHeadOU_Path1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ReviewApplicationAfterConsultation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ForwardApplicationToPRK</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_InformHeadOU_Path2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ForwardDismissalNoticeToHeadOU</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_JoinFinal</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_PrepareDocuments</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SettleAccounts</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_DismissalEnded</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Zarzad" name="Board (Trade Unions)">
        <bpmn:flowNodeRef>Task_IssueTradeUnionOpinion</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_SOP" name="LSS (Legal Service Section)">
        <bpmn:flowNodeRef>Task_ReviewDraftApplication</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ParallelConsultations</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AgreeOnDismissalDraft</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_JoinConsultations</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_RKR" name="Rector (RKR)">
        <bpmn:flowNodeRef>Task_MakeDecisionRKR_Path1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_MakeDecisionRKR_Path2</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_PRN" name="Vice-Rector for Scientific Affairs (PRN)">
        <bpmn:flowNodeRef>Task_ReviewPRN_Path1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ReviewPRN_Path2</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_PRK" name="Vice-Rector for Education (PRK)">
        <bpmn:flowNodeRef>Task_ReviewPRK_Path1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ReviewPRK_Path2</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:userTask id="Task_ReviewApplicationEmployee" name="Review application and forward to PD">
      <bpmn:incoming>Flow_PathEmployee</bpmn:incoming>
      <bpmn:outgoing>Flow_ReviewEmployeeToReviewPD</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:startEvent id="StartEvent_ProcessInitiation" name="Dismissal process initiation">
      <bpmn:outgoing>Flow_ToWhoInitiatesGate</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:exclusiveGateway id="Gateway_WhoInitiates" name="Who initiates the dismissal?">
      <bpmn:incoming>Flow_ToWhoInitiatesGate</bpmn:incoming>
      <bpmn:outgoing>Flow_PathEmployee</bpmn:outgoing>
      <bpmn:outgoing>Flow_PathMUT</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_ReviewEmployeeToReviewPD" sourceRef="Task_ReviewApplicationEmployee" targetRef="Task_ReviewApplicationPD" />
    <bpmn:sequenceFlow id="Flow_ReviewPDToReviewPRK1" sourceRef="Task_ReviewApplicationPD" targetRef="Task_ReviewPRK_Path1" />
    <bpmn:sequenceFlow id="Flow_ReviewPRK1ToReviewPRN1" sourceRef="Task_ReviewPRK_Path1" targetRef="Task_ReviewPRN_Path1" />
    <bpmn:sequenceFlow id="Flow_ReviewPRN1ToDecisionRKR1" sourceRef="Task_ReviewPRN_Path1" targetRef="Task_MakeDecisionRKR_Path1" />
    <bpmn:sequenceFlow id="Flow_DecisionRKR1ToInformHeadOU1" sourceRef="Task_MakeDecisionRKR_Path1" target="Task_InformHeadOU_Path1" />
    <bpmn:sequenceFlow id="Flow_InformHeadOU1ToJoinFinal" sourceRef="Task_InformHeadOU_Path1" targetRef="Gateway_JoinFinal" />
    <bpmn:sequenceFlow id="Flow_JoinFinalToPrepareDocuments" sourceRef="Gateway_JoinFinal" targetRef="Task_PrepareDocuments" />
    <bpmn:sequenceFlow id="Flow_PrepareToSettleAccounts" sourceRef="Task_PrepareDocuments" targetRef="Task_SettleAccounts" />
    <bpmn:sequenceFlow id="Flow_SettleAccountsToDismissalEnded" sourceRef="Task_SettleAccounts" targetRef="EndEvent_DismissalEnded" />
    <bpmn:sequenceFlow id="Flow_ConsultDraftToReviewDraft" sourceRef="Task_ConsultDraftWithLSS" targetRef="Task_ReviewDraftApplication" />
    <bpmn:sequenceFlow id="Flow_ReviewDraftToSubmitApplication" sourceRef="Task_ReviewDraftApplication" targetRef="Task_SubmitApplicationToPD" />
    <bpmn:sequenceFlow id="Flow_SubmitApplicationToParallelGate" sourceRef="Task_SubmitApplicationToPD" targetRef="Gateway_ParallelConsultations" />
    <bpmn:sequenceFlow id="Flow_ParallelGateToTradeUnionOpinion" sourceRef="Gateway_ParallelConsultations" targetRef="Task_IssueTradeUnionOpinion" />
    <bpmn:sequenceFlow id="Flow_ParallelGateToAgreeDraft" sourceRef="Gateway_ParallelConsultations" targetRef="Task_AgreeOnDismissalDraft" />
    <bpmn:sequenceFlow id="Flow_TradeUnionOpinionToJoinConsultation" sourceRef="Task_IssueTradeUnionOpinion" targetRef="Gateway_JoinConsultations" />
    <bpmn:sequenceFlow id="Flow_AgreeDraftToJoinConsultation" sourceRef="Task_AgreeOnDismissalDraft" targetRef="Gateway_JoinConsultations" />
    <bpmn:sequenceFlow id="Flow_JoinConsultationToReviewAfter" sourceRef="Gateway_JoinConsultations" targetRef="Task_ReviewApplicationAfterConsultation" />
    <bpmn:sequenceFlow id="Flow_ReviewAfterToForwardToPRK" sourceRef="Task_ReviewApplicationAfterConsultation" targetRef="Task_ForwardApplicationToPRK" />
    <bpmn:sequenceFlow id="Flow_ForwardToPRKToReviewPRK2" sourceRef="Task_ForwardApplicationToPRK" targetRef="Task_ReviewPRK_Path2" />
    <bpmn:sequenceFlow id="Flow_ReviewPRK2ToReviewPRN2" sourceRef="Task_ReviewPRK_Path2" targetRef="Task_ReviewPRN_Path2" />
    <bpmn:sequenceFlow id="Flow_ReviewPRN2ToDecisionRKR2" sourceRef="Task_ReviewPRN_Path2" targetRef="Task_MakeDecisionRKR_Path2" />
    <bpmn:sequenceFlow id="Flow_DecisionRKR2ToInformHeadOU2" sourceRef="Task_MakeDecisionRKR_Path2" targetRef="Task_InformHeadOU_Path2" />
    <bpmn:sequenceFlow id="Flow_InformHeadOU2ToForwardDismissal" sourceRef="Task_InformHeadOU_Path2" targetRef="Task_ForwardDismissalNoticeToHeadOU" />
    <bpmn:sequenceFlow id="Flow_ForwardDismissalToHandOver" sourceRef="Task_ForwardDismissalNoticeToHeadOU" targetRef="Task_HandOverDismissalNotice" />
    <bpmn:sequenceFlow id="Flow_HandOverToJoinFinal" sourceRef="Task_HandOverDismissalNotice" targetRef="Gateway_JoinFinal" />
    <bpmn:sequenceFlow id="Flow_ToWhoInitiatesGate" sourceRef="StartEvent_ProcessInitiation" targetRef="Gateway_WhoInitiates" />
    <bpmn:sequenceFlow id="Flow_PathEmployee" name="Employee" sourceRef="Gateway_WhoInitiates" targetRef="Task_ReviewApplicationEmployee" />
    <bpmn:sequenceFlow id="Flow_PathMUT" name="MUT" sourceRef="Gateway_WhoInitiates" targetRef="Task_ConsultDraftWithLSS" />
    <bpmn:userTask id="Task_ConsultDraftWithLSS" name="Consult draft application with LSS">
      <bpmn:incoming>Flow_PathMUT</bpmn:incoming>
      <bpmn:outgoing>Flow_ConsultDraftToReviewDraft</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_SubmitApplicationToPD" name="Submit application to PD (after consultation with LSS)">
      <bpmn:incoming>Flow_ReviewDraftToSubmitApplication</bpmn:incoming>
      <bpmn:outgoing>Flow_SubmitApplicationToParallelGate</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_ReviewApplicationPD" name="Review application (legal compliance) and forward to PRK">
      <bpmn:incoming>Flow_ReviewEmployeeToReviewPD</bpmn:incoming>
      <bpmn:outgoing>Flow_ReviewPDToReviewPRK1</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_InformHeadOU_Path1" name="Inform Head of O.U. about Rector&#39;s decision">
      <bpmn:incoming>Flow_DecisionRKR1ToInformHeadOU1</bpmn:incoming>
      <bpmn:incoming>Flow_1bw23ns</bpmn:incoming>
      <bpmn:outgoing>Flow_InformHeadOU1ToJoinFinal</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_ReviewPRK_Path1" name="Review application (PRK) and forward to PRN">
      <bpmn:incoming>Flow_ReviewPDToReviewPRK1</bpmn:incoming>
      <bpmn:outgoing>Flow_ReviewPRK1ToReviewPRN1</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_ReviewPRN_Path1" name="Review application (PRN) and forward to Rector">
      <bpmn:incoming>Flow_ReviewPRK1ToReviewPRN1</bpmn:incoming>
      <bpmn:outgoing>Flow_ReviewPRN1ToDecisionRKR1</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_MakeDecisionRKR_Path1" name="Make decision and forward to PD">
      <bpmn:incoming>Flow_ReviewPRN1ToDecisionRKR1</bpmn:incoming>
      <bpmn:outgoing>Flow_DecisionRKR1ToInformHeadOU1</bpmn:outgoing>
      <bpmn:outgoing>Flow_1bw23ns</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_ReviewDraftApplication" name="Review draft application (LSS)">
      <bpmn:incoming>Flow_ConsultDraftToReviewDraft</bpmn:incoming>
      <bpmn:outgoing>Flow_ReviewDraftToSubmitApplication</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:parallelGateway id="Gateway_ParallelConsultations" name="Start consultations">
      <bpmn:incoming>Flow_SubmitApplicationToParallelGate</bpmn:incoming>
      <bpmn:outgoing>Flow_ParallelGateToTradeUnionOpinion</bpmn:outgoing>
      <bpmn:outgoing>Flow_ParallelGateToAgreeDraft</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:userTask id="Task_IssueTradeUnionOpinion" name="Issue opinion (Trade Unions)">
      <bpmn:incoming>Flow_ParallelGateToTradeUnionOpinion</bpmn:incoming>
      <bpmn:outgoing>Flow_TradeUnionOpinionToJoinConsultation</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_AgreeOnDismissalDraft" name="Agree on dismissal draft (with LSS)">
      <bpmn:incoming>Flow_ParallelGateToAgreeDraft</bpmn:incoming>
      <bpmn:outgoing>Flow_AgreeDraftToJoinConsultation</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:parallelGateway id="Gateway_JoinConsultations">
      <bpmn:incoming>Flow_TradeUnionOpinionToJoinConsultation</bpmn:incoming>
      <bpmn:incoming>Flow_AgreeDraftToJoinConsultation</bpmn:incoming>
      <bpmn:outgoing>Flow_JoinConsultationToReviewAfter</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:userTask id="Task_ReviewApplicationAfterConsultation" name="Review application (after consultations)">
      <bpmn:incoming>Flow_JoinConsultationToReviewAfter</bpmn:incoming>
      <bpmn:outgoing>Flow_ReviewAfterToForwardToPRK</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_ForwardApplicationToPRK" name="Forward application with opinion to PRK">
      <bpmn:incoming>Flow_ReviewAfterToForwardToPRK</bpmn:incoming>
      <bpmn:outgoing>Flow_ForwardToPRKToReviewPRK2</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_ReviewPRK_Path2" name="Review application (PRK) and forward to PRN">
      <bpmn:incoming>Flow_ForwardToPRKToReviewPRK2</bpmn:incoming>
      <bpmn:outgoing>Flow_ReviewPRK2ToReviewPRN2</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_ReviewPRN_Path2" name="Review application (PRN) and forward to Rector">
      <bpmn:incoming>Flow_ReviewPRK2ToReviewPRN2</bpmn:incoming>
      <bpmn:outgoing>Flow_ReviewPRN2ToDecisionRKR2</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_MakeDecisionRKR_Path2" name="Make decision and sign dismissal notice">
      <bpmn:incoming>Flow_ReviewPRN2ToDecisionRKR2</bpmn:incoming>
      <bpmn:outgoing>Flow_DecisionRKR2ToInformHeadOU2</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_InformHeadOU_Path2" name="Inform Head of O.U. about Rector&#39;s decision">
      <bpmn:incoming>Flow_DecisionRKR2ToInformHeadOU2</bpmn:incoming>
      <bpmn:outgoing>Flow_InformHeadOU2ToForwardDismissal</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_ForwardDismissalNoticeToHeadOU" name="Forward dismissal notice to Head of O.U.">
      <bpmn:incoming>Flow_InformHeadOU2ToForwardDismissal</bpmn:incoming>
      <bpmn:outgoing>Flow_ForwardDismissalToHandOver</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_HandOverDismissalNotice" name="Hand dismissal notice to employee">
      <bpmn:incoming>Flow_ForwardDismissalToHandOver</bpmn:incoming>
      <bpmn:outgoing>Flow_HandOverToJoinFinal</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_JoinFinal">
      <bpmn:incoming>Flow_InformHeadOU1ToJoinFinal</bpmn:incoming>
      <bpmn:incoming>Flow_HandOverToJoinFinal</bpmn:incoming>
      <bpmn:outgoing>Flow_JoinFinalToPrepareDocuments</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_PrepareDocuments" name="Prepare documents (Form 30/PD)">
      <bpmn:incoming>Flow_JoinFinalToPrepareDocuments</bpmn:incoming>
      <bpmn:outgoing>Flow_PrepareToSettleAccounts</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_SettleAccounts" name="Settle accounts with dismissed employee">
      <bpmn:incoming>Flow_PrepareToSettleAccounts</bpmn:incoming>
      <bpmn:outgoing>Flow_SettleAccountsToDismissalEnded</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="EndEvent_DismissalEnded" name="Dismissal process ended">
      <bpmn:incoming>Flow_SettleAccountsToDismissalEnded</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1bw23ns" sourceRef="Task_MakeDecisionRKR_Path1" targetRef="Task_InformHeadOU_Path1" />
  </bpmn:process>
